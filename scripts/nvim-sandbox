#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

PROFILE="${NVIM_PROFILE:-private}"
if [[ "${1:-}" == "work" || "${1:-}" == "private" ]]; then
  PROFILE="$1"
  shift
fi

export XDG_CONFIG_HOME="$ROOT/.sandbox/config"
export XDG_DATA_HOME="$ROOT/.sandbox/data"
export XDG_STATE_HOME="$ROOT/.sandbox/state"
export XDG_CACHE_HOME="$ROOT/.sandbox/cache"
export NVIM_PROFILE="$PROFILE"

mkdir -p "$XDG_CONFIG_HOME" "$XDG_DATA_HOME" "$XDG_STATE_HOME" "$XDG_CACHE_HOME"
ln -sfn "$ROOT" "$XDG_CONFIG_HOME/nvim"

exec nvim "$@"
